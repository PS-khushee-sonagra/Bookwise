# BookWise AI Configuration

# Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Name (Optional, defaults to gemini-flash-latest)
GEMINI_MODEL=gemini-flash-latest

# Similarity Threshold for RAG retrieval filtering (Optional, defaults to 0.35)
SIMILARITY_THRESHOLD=0.35
